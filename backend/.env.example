# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Defaults to SQLite for local development)
DATABASE_URL="file:./dev.db"

# JWT Configuration
JWT_ACCESS_SECRET=your_jwt_access_secret_here_make_it_long_and_secure
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_make_it_long_and_secure
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google Gemini AI Config
GEMINI_API_KEY=your_gemini_api_key_here

# Notification settings - SMTP (Email)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="PulseCare AI Alerts <alerts@pulsecare.ai>"

# Notification settings - Twilio SMS (Ready for integration)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
ENABLE_TWILIO_SMS=false
